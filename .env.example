# ─── Azure OpenAI ─────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-api-key>
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4.1-nano
AZURE_OPENAI_CHAT_MODEL_VERSION=2025-04-14
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/doutortrabalho
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# ─── Keycloak ─────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_AUTH_SERVER_URL=http://localhost:8180
KEYCLOAK_REALM=doutor-trabalho

# ─── Redis ────────────────────────────────────────────────
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379

# ─── pgAdmin (dev only) ───────────────────────────────────
PGADMIN_EMAIL=admin@doutortrabalho.pt
PGADMIN_PASSWORD=admin

# ─── Application ──────────────────────────────────────────
APP_BASE_URL=http://localhost:8080
APP_CORS_ORIGINS=http://localhost:3000
